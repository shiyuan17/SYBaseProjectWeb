{
  "name": "sy-base-project-web",
  "version": "5.7.0",
  "private": true,
  "keywords": [
    "monorepo",
    "turbo",
    "vben",
    "vben admin",
    "vben pro",
    "vue",
    "vue admin",
    "vue vben admin",
    "vue vben admin pro",
    "vue3"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/run-with-log.mjs .logs/build.log cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo build",
    "build:ele": "pnpm run build --filter=@vben/web-ele",
    "check": "pnpm run check:circular && pnpm run check:dep && pnpm run check:type && pnpm check:cspell && pnpm run check:governance",
    "check:governance": "node ./scripts/validate-governance.mjs",
    "check:circular": "vsh check-circular",
    "check:cspell": "cspell lint \"**/*.{ts,tsx,vue}\" \"**/README.md\" \"docs/**/*.md\" \"*.md\" --no-progress",
    "check:dep": "vsh check-dep",
    "check:type": "turbo run typecheck",
    "clean": "node ./scripts/clean.mjs",
    "dev": "turbo-run dev",
    "dev:ele": "node ./scripts/run-with-log.mjs .logs/frontend.log pnpm -F @vben/web-ele run dev",
    "lint": "vsh lint",
    "linear:pull": "node ./scripts/linear-sync.mjs pull",
    "linear:register": "node ./scripts/linear-sync.mjs register",
    "linear:sync": "node ./scripts/linear-sync.mjs sync",
    "postinstall": "pnpm -r run stub --if-present",
    "preinstall": "npx only-allow pnpm",
    "preview": "turbo-run preview",
    "test:system-management": "node ./scripts/test-system-management.mjs all",
    "test:system-management:backend": "node ./scripts/test-system-management.mjs backend",
    "test:system-management:frontend": "node ./scripts/test-system-management.mjs frontend",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:unit": "node ./scripts/run-with-log.mjs .logs/test.log vitest run --dom"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@tsdown/css": "catalog:",
    "@types/node": "catalog:",
    "@vben/commitlint-config": "workspace:*",
    "@vben/eslint-config": "workspace:*",
    "@vben/oxfmt-config": "workspace:*",
    "@vben/oxlint-config": "workspace:*",
    "@vben/stylelint-config": "workspace:*",
    "@vben/tailwind-config": "workspace:*",
    "@vben/tsconfig": "workspace:*",
    "@vben/turbo-run": "workspace:*",
    "@vben/vite-config": "workspace:*",
    "@vben/vsh": "workspace:*",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "cross-env": "catalog:",
    "cspell": "catalog:",
    "happy-dom": "catalog:",
    "is-ci": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || ^22.18.0 || ^24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
